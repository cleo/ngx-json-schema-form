{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "jsf": {
      "projectType": "library",
      "root": "projects/jsf",
      "sourceRoot": "projects/jsf/src",
      "prefix": "jsf",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "options": {
            "tsConfig": "projects/jsf/tsconfig.lib.json",
            "project": "projects/jsf/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/jsf/tsconfig.lib.prod.json"
            }
          }
        },
        "test": {
          "builder": "@angular/build:karma",
          "options": {
            "main": "projects/jsf/src/test.ts",
            "tsConfig": "projects/jsf/tsconfig.spec.json",
            "karmaConfig": "projects/jsf/karma.conf.js"
          }
        }
      }
    },
    "jsf-launcher": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "projects/jsf-launcher",
      "sourceRoot": "projects/jsf-launcher/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": {
              "base": "dist/jsf-launcher"
            },
            "index": "projects/jsf-launcher/src/index.html",
            "polyfills": [
              "projects/jsf-launcher/src/polyfills.ts"
            ],
            "tsConfig": "projects/jsf-launcher/tsconfig.app.json",
            "assets": [
              "projects/jsf-launcher/src/favicon.ico",
              "projects/jsf-launcher/src/assets"
            ],
            "styles": [
              "projects/jsf-launcher/src/styles.scss",
              "node_modules/bootstrap-sass/assets/stylesheets/_bootstrap.scss"
            ],
            "scripts": [],
            "extractLicenses": false,
            "sourceMap": true,
            "optimization": false,
            "namedChunks": true,
            "browser": "projects/jsf-launcher/src/main.ts"
          },
          "configurations": {
            "production": {
              "fileReplacements": [
                {
                  "replace": "projects/jsf-launcher/src/environments/environment.ts",
                  "with": "projects/jsf-launcher/src/environments/environment.prod.ts"
                }
              ],
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "namedChunks": false,
              "extractLicenses": true,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2mb",
                  "maximumError": "5mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kb",
                  "maximumError": "10kb"
                }
              ]
            }
          },
          "defaultConfiguration": ""
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "buildTarget": "jsf-launcher:build"
          },
          "configurations": {
            "production": {
              "buildTarget": "jsf-launcher:build:production"
            }
          }
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n",
          "options": {
            "buildTarget": "jsf-launcher:build"
          }
        },
        "test": {
          "builder": "@angular/build:karma",
          "options": {
            "main": "projects/jsf-launcher/src/test.ts",
            "polyfills": "projects/jsf-launcher/src/polyfills.ts",
            "tsConfig": "projects/jsf-launcher/tsconfig.spec.json",
            "karmaConfig": "projects/jsf-launcher/karma.conf.js",
            "assets": [
              "projects/jsf-launcher/src/favicon.ico",
              "projects/jsf-launcher/src/assets"
            ],
            "styles": [
              "projects/jsf-launcher/src/styles.scss"
            ],
            "scripts": []
          }
        }
      }
    },
    "jsf-validation": {
      "projectType": "library",
      "root": "projects/jsf-validation",
      "sourceRoot": "projects/jsf-validation/src",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "options": {
            "tsConfig": "projects/jsf-validation/tsconfig.lib.json",
            "project": "projects/jsf-validation/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/jsf-validation/tsconfig.lib.prod.json"
            }
          }
        },
        "test": {
          "builder": "@angular/build:karma",
          "options": {
            "main": "projects/jsf-validation/src/test.ts",
            "tsConfig": "projects/jsf-validation/tsconfig.spec.json",
            "karmaConfig": "projects/jsf-validation/karma.conf.js"
          }
        }
      }
    },
    "jsf-demo": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss",
          "standalone": true
        }
      },
      "root": "projects/jsf-demo",
      "sourceRoot": "projects/jsf-demo/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": {
              "base": "dist/jsf-demo"
            },
            "index": "projects/jsf-demo/src/index.html",
            "browser": "projects/jsf-demo/src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "projects/jsf-demo/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              "projects/jsf-demo/src/favicon.ico",
              "projects/jsf-demo/src/assets",
              {
                "glob": "**/*",
                "input": "projects/jsf-launcher/src/assets/jsf-images",
                "output": "/assets/jsf-images"
              },
              {
                "glob": "**/*",
                "input": "node_modules/bootstrap-sass/assets/fonts/",
                "output": "/fonts/"
              }
            ],
            "styles": [
              "projects/jsf-demo/src/bootstrap-custom.scss",
              "projects/jsf-demo/src/styles.scss"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "2kB",
                  "maximumError": "4kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "buildTarget": "jsf-demo:build"
          },
          "configurations": {
            "production": {
              "buildTarget": "jsf-demo:build:production"
            },
            "development": {
              "buildTarget": "jsf-demo:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n"
        }
      }
    }
  },
  "schematics": {
    "@schematics/angular:component": {
      "type": "component"
    },
    "@schematics/angular:directive": {
      "type": "directive"
    },
    "@schematics/angular:service": {
      "type": "service"
    },
    "@schematics/angular:guard": {
      "typeSeparator": "."
    },
    "@schematics/angular:interceptor": {
      "typeSeparator": "."
    },
    "@schematics/angular:module": {
      "typeSeparator": "."
    },
    "@schematics/angular:pipe": {
      "typeSeparator": "."
    },
    "@schematics/angular:resolver": {
      "typeSeparator": "."
    }
  }
}