{
  "name": "json-schema-form",
  "version": "1.0.0",
  "scripts": {
    "build-jsf-prod": "ng build jsf --configuration=production",
    "build-jsf-validation-prod": "ng build jsf-validation --configuration=production",
    "publish": "npm run publish-jsf && npm run publish-jsf-validation",
    "publish-jsf": "ng build jsf --configuration=production && cd ./dist/jsf && npm publish --access public",
    "publish-jsf-validation": "ng build jsf-validation --configuration=production && cd ./dist/jsf-validation && npm publish --access public",
    "ng": "ng",
    "serve": "ng serve",
    "build": "ng build",
    "test": "ng test",
    "test-validation": "ng test jsf-validation",
    "lint": "eslint --format unix .",
    "lint-fix": "eslint --format unix . --fix"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "20.3.16",
    "@angular/common": "20.3.16",
    "@angular/compiler": "20.3.16",
    "@angular/core": "20.3.16",
    "@angular/forms": "20.3.16",
    "@angular/platform-browser": "20.3.16",
    "@angular/platform-browser-dynamic": "20.3.16",
    "@angular/router": "20.3.16",
    "ag-grid-angular": "35.0.0",
    "ag-grid-community": "35.0.0",
    "ajv": "6.12.6",
    "ajv-keywords": "3.5.2",
    "bootstrap-sass": "3.4.3",
    "ng-packagr": "^20.3.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-eslint/eslint-plugin": "^20.7.0",
    "@angular-eslint/eslint-plugin-template": "^20.7.0",
    "@angular-eslint/template-parser": "^20.7.0",
    "@angular/build": "^20.3.15",
    "@angular/cli": "20.3.15",
    "@angular/compiler-cli": "20.3.16",
    "@angular/language-service": "20.3.16",
    "@types/jasmine": "~3.6.0",
    "@types/jasminewd2": "2.0.3",
    "@types/lodash": "4.14.168",
    "@types/node": "18.19.24",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "eslint": "^8.33.0",
    "jasmine-core": "~4.6.0",
    "jasmine-spec-reporter": "~5.0.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.1.0",
